{
  "name": "centipede",
  "version": "0.1.0",
  "description": "Project Cockpit — a lightweight desktop coding app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "dev:server": "node scripts/dev-server.cjs",
    "dev:browser": "node scripts/dev-browser.cjs",
    "build": "electron-vite build",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "postinstall": "electron-builder install-app-deps && chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "nanoid": "^5.1.5",
    "node-pty": "^1.1.0",
    "tailwind-merge": "^3.0.2",
    "ws": "^8.20.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
