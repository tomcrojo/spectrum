{
  "name": "spectrum",
  "version": "0.1.0",
  "description": "Desktop project cockpit for coding work with dashboards, workspaces, terminals, browser panels, and agent flows",
  "license": "MIT",
  "author": "Tomas Campoy",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "electron",
    "desktop",
    "developer-tools",
    "project-management",
    "terminal",
    "workspace"
  ],
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "dev:server": "node scripts/dev-server.cjs",
    "dev:browser": "node scripts/dev-browser.cjs",
    "benchmark:perf": "node scripts/perf-benchmark.mjs",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "prepare:packaged-runtime": "node scripts/prepare-packaged-runtime.cjs",
    "dist": "npm run build && npm run prepare:packaged-runtime && electron-builder --publish never",
    "dist:mac": "npm run build && npm run prepare:packaged-runtime && electron-builder --mac dmg --publish never",
    "dist:mac:dir": "npm run build && npm run prepare:packaged-runtime && electron-builder --mac dir --publish never",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "postinstall": "electron-builder install-app-deps && chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "monaco-editor": "^0.52.2",
    "nanoid": "^5.1.5",
    "node-pty": "^1.1.0",
    "playwright-core": "^1.58.2",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
